# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs allowed to use the bot
# Send /start to the bot to see your chat ID, then add it here
ALLOWED_CHAT_IDS=

# LLM API key (required for provider: "api"; not needed for local ollama)
# OpenRouter: https://openrouter.ai/keys
LLM_API_KEY=
